module registrador_OP(
	input [3:0] OP,
	input clk,
	input en,
	output [3:0] LED
);
	flipflop_D_descida flip0(
	.d(OP[0]), .clk(clk),	.rst_n(1'b1),	.en(en),	.q(LED[0])
);
	
	flipflop_D_descida flip1(
	.d(OP[1]), .clk(clk), .rst_n(1'b1), .en(en), .q(LED[1])
);
	flipflop_D_descida flip2(
	.d(OP[2]), .clk(clk), .rst_n(1'b1), .en(en), .q(LED[2])
);

endmodule