// =====================================================
// MÓDULO 1: MÁQUINA DE ESTADOS
// =====================================================
module maquina_estados_mult(
    input clk,
    input rst,
    input start,
    input [3:0] contador,
    output state_idle,
    output state_multiply,
    output state_done
);
    // Estados: 00=IDLE, 01=MULTIPLY, 10=DONE
    wire [1:0] state, next_state;
    
    // Registradores de estado
    flipflop_D_descida ff_state0(
        .d(next_state[0]),
        .clk(clk),
        .rst_n(~rst),
        .en(1'b1),
        .q(state[0])
    );
    
    flipflop_D_descida ff_state1(
        .d(next_state[1]),
        .clk(clk),
        .rst_n(~rst),
        .en(1'b1),
        .q(state[1])
    );
    
    // Decodificação dos estados
    wire n_state0, n_state1;
    not Not0(n_state0, state[0]);
    not Not1(n_state1, state[1]);
    
    and And_idle(state_idle, n_state1, n_state0);      // 00
    and And_mult(state_multiply, n_state1, state[0]);  // 01
    and And_done(state_done, state[1], n_state0);      // 10
    
    // Lógica de próximo estado
    wire contador_8;  // contador == 8
    wire w0, w1, w2, w3;
    
    // contador == 8
    and And_c8_0(w0, contador[3], ~contador[2]);
    and And_c8_1(w1, ~contador[1], ~contador[0]);
    and And_c8(contador_8, w0, w1);
    
    // Next state logic
    // IDLE -> MULTIPLY quando start=1
    // MULTIPLY -> DONE quando contador=8
    // DONE -> IDLE sempre
    
    wire idle_to_mult, mult_to_done;
    and And_idle_mult(idle_to_mult, state_idle, start);
    and And_mult_done(mult_to_done, state_multiply, contador_8);
    
    // next_state[0] = (IDLE & start) | (MULTIPLY & ~contador_8)
    wire mult_continue;
    and And_mult_cont(mult_continue, state_multiply, ~contador_8);
    or Or_ns0(next_state[0], idle_to_mult, mult_continue);
    
    // next_state[1] = (MULTIPLY & contador_8)
    buf Buf_ns1(next_state[1], mult_to_done);
    
endmodule

// =====================================================
// MÓDULO 2: CONTADOR DE 4 BITS
// =====================================================
module contador_4bits(
    input clk,
    input rst,
    input en,
    output [3:0] Q
);
    wire [3:0] Q_next;
    wire [3:0] carry;
    
    // Bit 0: sempre inverte quando en=1
    xor Xor0(Q_next[0], Q[0], en);
    
    flipflop_D_descida ff0(
        .d(Q_next[0]),
        .clk(clk),
        .rst_n(~rst),
        .en(1'b1),
        .q(Q[0])
    );
    
    // Carry para bit 1
    and And_c0(carry[0], Q[0], en);
    
    // Bit 1
    xor Xor1(Q_next[1], Q[1], carry[0]);
    
    flipflop_D_descida ff1(
        .d(Q_next[1]),
        .clk(clk),
        .rst_n(~rst),
        .en(1'b1),
        .q(Q[1])
    );
    
    // Carry para bit 2
    and And_c1(carry[1], Q[1], carry[0]);
    
    // Bit 2
    xor Xor2(Q_next[2], Q[2], carry[1]);
    
    flipflop_D_descida ff2(
        .d(Q_next[2]),
        .clk(clk),
        .rst_n(~rst),
        .en(1'b1),
        .q(Q[2])
    );
    
    // Carry para bit 3
    and And_c2(carry[2], Q[2], carry[1]);
    
    // Bit 3
    xor Xor3(Q_next[3], Q[3], carry[2]);
    
    flipflop_D_descida ff3(
        .d(Q_next[3]),
        .clk(clk),
        .rst_n(~rst),
        .en(1'b1),
        .q(Q[3])
    );
    
endmodule

// =====================================================
// MÓDULO 3: DESLOCADOR VARIÁVEL (Shift Left)
// =====================================================
module deslocador_variavel(
    input [7:0] A,
    input [2:0] shift_amount,
    output [15:0] Y
);
    // A << shift_amount (com extensão para 16 bits)
    // shift_amount pode ser 0 a 7
    
    wire [15:0] shift0, shift1, shift2, shift3, shift4, shift5, shift6, shift7;
    
    // Shift 0 (sem deslocamento)
    assign shift0[7:0] = A;
    assign shift0[15:8] = 8'b0;
    
    // Shift 1
    assign shift1[0] = 1'b0;
    assign shift1[8:1] = A;
    assign shift1[15:9] = 7'b0;
    
    // Shift 2
    assign shift2[1:0] = 2'b0;
    assign shift2[9:2] = A;
    assign shift2[15:10] = 6'b0;
    
    // Shift 3
    assign shift3[2:0] = 3'b0;
    assign shift3[10:3] = A;
    assign shift3[15:11] = 5'b0;
    
    // Shift 4
    assign shift4[3:0] = 4'b0;
    assign shift4[11:4] = A;
    assign shift4[15:12] = 4'b0;
    
    // Shift 5
    assign shift5[4:0] = 5'b0;
    assign shift5[12:5] = A;
    assign shift5[15:13] = 3'b0;
    
    // Shift 6
    assign shift6[5:0] = 6'b0;
    assign shift6[13:6] = A;
    assign shift6[15:14] = 2'b0;
    
    // Shift 7
    assign shift7[6:0] = 7'b0;
    assign shift7[14:7] = A;
    assign shift7[15] = 1'b0;
    
    // MUX 8:1 para selecionar o shift correto
    mux_16bits_8x1 mux_shift(
        .in0(shift0), .in1(shift1), .in2(shift2), .in3(shift3),
        .in4(shift4), .in5(shift5), .in6(shift6), .in7(shift7),
        .sel(shift_amount),
        .out(Y)
    );
    
endmodule

// =====================================================
// MÓDULO 4: MUX 16 BITS 8:1
// =====================================================
module mux_16bits_8x1(
    input [15:0] in0, in1, in2, in3, in4, in5, in6, in7,
    input [2:0] sel,
    output [15:0] out
);
    genvar i;
    generate
        for (i = 0; i < 16; i = i + 1) begin : mux_bits
            mux_1bit_8x1 mux_i(
                .in0(in0[i]), .in1(in1[i]), .in2(in2[i]), .in3(in3[i]),
                .in4(in4[i]), .in5(in5[i]), .in6(in6[i]), .in7(in7[i]),
                .sel(sel),
                .out(out[i])
            );
        end
    endgenerate
endmodule

// MUX 1 bit 8:1
module mux_1bit_8x1(
    input in0, in1, in2, in3, in4, in5, in6, in7,
    input [2:0] sel,
    output out
);
    wire n_sel0, n_sel1, n_sel2;
    wire and0, and1, and2, and3, and4, and5, and6, and7;
    
    not Not0(n_sel0, sel[0]);
    not Not1(n_sel1, sel[1]);
    not Not2(n_sel2, sel[2]);
    
    // Decodificação
    wire [7:0] decode;
    and And0(decode[0], n_sel2, n_sel1, n_sel0);
    and And1(decode[1], n_sel2, n_sel1, sel[0]);
    and And2(decode[2], n_sel2, sel[1], n_sel0);
    and And3(decode[3], n_sel2, sel[1], sel[0]);
    and And4(decode[4], sel[2], n_sel1, n_sel0);
    and And5(decode[5], sel[2], n_sel1, sel[0]);
    and And6(decode[6], sel[2], sel[1], n_sel0);
    and And7(decode[7], sel[2], sel[1], sel[0]);
    
    // Seleção
    and And_0(and0, in0, decode[0]);
    and And_1(and1, in1, decode[1]);
    and And_2(and2, in2, decode[2]);
    and And_3(and3, in3, decode[3]);
    and And_4(and4, in4, decode[4]);
    and And_5(and5, in5, decode[5]);
    and And_6(and6, in6, decode[6]);
    and And_7(and7, in7, decode[7]);
    
    // OR final
    wire or01, or23, or45, or67, or0123, or4567;
    or Or01(or01, and0, and1);
    or Or23(or23, and2, and3);
    or Or45(or45, and4, and5);
    or Or67(or67, and6, and7);
    or Or0123(or0123, or01, or23);
    or Or4567(or4567, or45, or67);
    or Or_final(out, or0123, or4567);
    
endmodule

// =====================================================
// MÓDULO 5: MUX 16 BITS 2:1
// =====================================================
module mux_16bits_2x1(
    input [15:0] in0,
    input [15:0] in1,
    input sel,
    output [15:0] out
);
    genvar i;
    generate
        for (i = 0; i < 16; i = i + 1) begin : mux_bit
            wire n_sel, and0, and1;
            not Not_sel(n_sel, sel);
            and And0(and0, in0[i], n_sel);
            and And1(and1, in1[i], sel);
            or Or_out(out[i], and0, and1);
        end
    endgenerate
endmodule

// =====================================================
// MÓDULO 6: MUX 8 BITS 2:1
// =====================================================
module mux_8bits_2x1(
    input [7:0] in0,
    input [7:0] in1,
    input sel,
    output [7:0] out
);
    genvar i;
    generate
        for (i = 0; i < 8; i = i + 1) begin : mux_bit
            wire n_sel, and0, and1;
            not Not_sel(n_sel, sel);
            and And0(and0, in0[i], n_sel);
            and And1(and1, in1[i], sel);
            or Or_out(out[i], and0, and1);
        end
    endgenerate
endmodule

// =====================================================
// MÓDULO 7: SHIFT RIGHT 8 BITS
// =====================================================
module shift_right_8bits(
    input [7:0] D,
    output [7:0] Q
);
    // Shift right lógico: Q = D >> 1
    buf Buf0(Q[0], D[1]);
    buf Buf1(Q[1], D[2]);
    buf Buf2(Q[2], D[3]);
    buf Buf3(Q[3], D[4]);
    buf Buf4(Q[4], D[5]);
    buf Buf5(Q[5], D[6]);
    buf Buf6(Q[6], D[7]);
    buf Buf7(Q[7], 1'b0);  // MSB = 0
endmodule

// =====================================================
// MÓDULO 8: MULTIPLICADOR RECURSIVO (VERSÃO CORRIGIDA)
// =====================================================
module multiplicador_8bits_recursivo(
    input [7:0] A,
    input [7:0] B,
    input clk,
    input start,
    input rst,
    output [7:0] P,
    output done
);

    // Registrador acumulador (16 bits)
    wire [15:0] acumulador_in, acumulador_out;
    wire load_acumulador;
    
    registrador_16bits reg_acumulador(
        .D(acumulador_in),
        .clk(clk),
        .rst(rst),
        .en(load_acumulador),
        .Q(acumulador_out)
    );
    
    // Registrador multiplicando (A)
    wire [7:0] multiplicando_out;
    wire load_multiplicando;
    
    registrador8bits reg_multiplicando(
        .ENT(A),
        .clk(clk),
        .en(load_multiplicando),
        .S(multiplicando_out)
    );
    
    // Registrador multiplicador (B)
    wire [7:0] multiplicador_in, multiplicador_out;
    wire load_multiplicador;
    
    registrador8bits reg_multiplicador(
        .ENT(multiplicador_in),
        .clk(clk),
        .en(load_multiplicador),
        .S(multiplicador_out)
    );
    
    // Contador (0 a 8)
    wire [3:0] contador_out;
    wire inc_contador, rst_contador;
    
    contador_4bits cont(
        .clk(clk),
        .rst(rst_contador),
        .en(inc_contador),
        .Q(contador_out)
    );
    
    // Máquina de estados
    wire state_idle, state_multiply, state_done;
    
    maquina_estados_mult fsm(
        .clk(clk),
        .rst(rst),
        .start(start),
        .contador(contador_out),
        .state_idle(state_idle),
        .state_multiply(state_multiply),
        .state_done(state_done)
    );
    
    // Deslocador (shift A pela posição contador)
    wire [15:0] A_shifted;
    
    deslocador_variavel shift_A(
        .A(multiplicando_out),
        .shift_amount(contador_out[2:0]),
        .Y(A_shifted)
    );
    
    // Bit atual de B (LSB)
    wire bit_B_atual;
    buf Buf_bit(bit_B_atual, multiplicador_out[0]);
    
    // MUX: se bit_B_atual=1, soma A_shifted, senão soma 0
    wire [15:0] valor_a_somar;
    mux_16bits_2x1 mux_soma(
        .sel(bit_B_atual),
        .in0(16'b0),
        .in1(A_shifted),
        .out(valor_a_somar)
    );
    
    // SOMADOR DE 16 BITS
    wire [15:0] soma_result;
    wire cout_unused;
    
    somador_16bits somador_unico(
        .A(acumulador_out),
        .B(valor_a_somar),
        .Cin(1'b0),
        .S(soma_result),
        .Cout(cout_unused)
    );
    
    // Shift right para multiplicador (B >> 1)
    wire [7:0] multiplicador_shifted;
    
    shift_right_8bits shift_B(
        .D(multiplicador_out),
        .Q(multiplicador_shifted)
    );
    
    // LÓGICA DE CONTROLE
    wire load_acum_start, load_acum_multiply;
    and And_load_start(load_acum_start, state_idle, start);
    buf Buf_load_mult(load_acum_multiply, state_multiply);
    or Or_load_acum(load_acumulador, load_acum_start, load_acum_multiply);
    
    // Acumulador input: 0 no start, soma_result no multiply
    mux_16bits_2x1 mux_acum_in(
        .sel(state_multiply),
        .in0(16'b0),
        .in1(soma_result),
        .out(acumulador_in)
    );
    
    // Load multiplicando: apenas no start
    and And_load_mand(load_multiplicando, state_idle, start);
    
    // Load multiplicador: start ou multiply
    or Or_load_mdor(load_multiplicador, load_acum_start, load_acum_multiply);
    
    // Multiplicador input: B no start, shifted no multiply
    mux_8bits_2x1 mux_mdor_in(
        .sel(state_multiply),
        .in0(B),
        .in1(multiplicador_shifted),
        .out(multiplicador_in)
    );
    
    // Incrementa contador no multiply
    buf Buf_inc_cont(inc_contador, state_multiply);
    
    // Reset contador
    wire rst_cont_start;
    and And_rst_cont(rst_cont_start, state_idle, start);
    or Or_rst_cont_global(rst_contador, rst_cont_start, rst);
    
    // SATURAÇÃO
    wire overflow;
    or Or_ovf0(w_ovf0, acumulador_out[8], acumulador_out[9]);
    or Or_ovf1(w_ovf1, acumulador_out[10], acumulador_out[11]);
    or Or_ovf2(w_ovf2, acumulador_out[12], acumulador_out[13]);
    or Or_ovf3(w_ovf3, acumulador_out[14], acumulador_out[15]);
    or Or_ovf4(w_ovf4, w_ovf0, w_ovf1);
    or Or_ovf5(w_ovf5, w_ovf2, w_ovf3);
    or Or_ovf(overflow, w_ovf4, w_ovf5);
    
    // Saída: saturado ou normal
    mux_8bits_2x1 mux_output(
        .sel(overflow),
        .in0(acumulador_out[7:0]),
        .in1(8'b11111111),
        .out(P)
    );
    
    // Done quando estado = DONE
    buf Buf_done(done, state_done);

endmodule